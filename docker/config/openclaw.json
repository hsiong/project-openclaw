{
  "models": {
    "providers": {
      "volc_glm": {
        "baseUrl": "https://ark.cn-beijing.volces.com/api/v3",
        "apiKey": { "source": "file", "provider": "filemain", "id": "/volc-glm/apiKey" },
        "api": "openai-responses",
        "models": [
          {
            "id": "glm-4-7-251222",
            "name": "GLM-4"
          }
        ]
      },
      "glm": {
        "baseUrl": "https://open.bigmodel.cn/api/paas/v4",
        "apiKey": { "source": "file", "provider": "filemain", "id": "/glm/apiKey" },
        "api": "openai-completions",
        "models": [
          { "id": "glm-4.7", "name": "Zhipu GLM-4.7" }
        ]
      },
      "kimi": {
        "baseUrl": "https://api.moonshot.cn/v1",
        "apiKey": { "source": "file", "provider": "filemain", "id": "/kimi/apiKey" },
        "api": "openai-completions",
        "models": [
          { "id": "kimi-k2.5", "name": "Kimi K2.5" }
        ]
      },
      "tongyi": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": { "source": "file", "provider": "filemain", "id": "/tongyi/apiKey" },
        "api": "openai-completions",
        "models": [
          { "id": "kimi/kimi-k2.5", "name": "Tongyi Kimi K2.5" }
        ]
      },
      "ollama": {
        "baseUrl": "http://ollama.xxxx",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "moonlight16b:0317",
            "name": "Moonlight 16B",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 8192,
            "maxTokens": 8192
          },
          {
            "id": "qwen3:14b-q4_K_M",
            "name": "Qwen 3 14B",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 40960,
            "maxTokens": 10240
          },
          {
            "id": "qwen3.5:9b",
            "name": "Qwen 3.5 9B",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 10240
          },
          {
            "id": "qwen3.5:27b",
            "name": "Qwen 3.5 27B",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 10240
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": { "source": "file", "provider": "filemain", "id": "/gateway/token" }
    }
  },
  "secrets": {
    "providers": {
      "filemain": {
        "source": "file",
        "path": "~/.openclaw/secrets.json",
        "mode": "json"
      }
    },
    "defaults": {
      "file": "filemain"
    }
  },
  "agents": {
    "defaults": {
      "imageModel": { "primary": "ollama/qwen3.5:9b" },
      "model": {
        "primary":  "ollama/qwen3.5:9b",
        "fallbacks": [
          "ollama/qwen3.5:27b",
          "ollama/qwen3:14b-q4_K_M",
          "ollama/moonlight16b:0317",
          "glm/glm-4.6v",
          "volc_glm/glm-4-7-251222",
          "kimi/kimi-k2.5",
          "tongyi/kimi/kimi-k2.5"
        ]
      },
      "timeoutSeconds": 900,
      "workspace": "~/.openclaw/workspace",
      "sandbox": {
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "rw",
        "docker": {
          "image": "ccr.ccs.tencentyun.com/openclaw-jf/openclaw-sandbox:2026.3.12",
          "workdir": "/workspace",
          "readOnlyRoot": false,
          "tmpfs": ["/tmp", "/var/tmp", "/run"],
          "network": "none",
          "user": "0:0",
          "capDrop": ["ALL"],
          "pidsLimit": 256,
          "memory": "1g",
          "memorySwap": "2g",
          "cpus": 1,
          "env": {
            "LANG": "C.UTF-8"
          }
        },
        "browser": {
          "enabled": true,
          "image": "ccr.ccs.tencentyun.com/openclaw-jf/openclaw-sandbox-browser:2026.3.12",
          "allowHostControl": false
        }
      }
    }
  },
  "tools": {
    "profile": "full",
    "allow": [
      "group:runtime",
      "group:fs",
      "group:sessions",
      "group:ui",
      "group:automation",
      "group:nodes"
    ],
    "sandbox": {
      "tools": {
        "allow": [
          "group:runtime",
          "group:fs",
          "group:sessions",
          "group:ui",
          "group:automation",
          "group:nodes"
        ]
      }
    },
    "elevated": {
      "enabled": false
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "globalCircuitBreakerThreshold": 30,
      "detectors": {
        "genericRepeat": true,
        "knownPollNoProgress": true,
        "pingPong": true
      }
    }
  }
}
